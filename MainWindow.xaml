<Window x:Class="PicExif.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        Title="PicExif - 图片地理位置信息提取工具" 
        Height="850" Width="1200"
        MinHeight="750" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9FA"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextFormattingMode="Display">
    
    <Window.Resources>
        <!-- 颜色资源 -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#E1F5FE"/>
        <SolidColorBrush x:Key="AccentColor" Color="#005A9E"/>
        <SolidColorBrush x:Key="TextColor" Color="#333333"/>
        <SolidColorBrush x:Key="LightTextColor" Color="#666666"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#28A745"/>
        
        <!-- 列宽常数 -->
        <GridLength x:Key="TwoColumnLabelWidth">70</GridLength>
        <GridLength x:Key="TwoColumnValueWidth">*</GridLength>
        <GridLength x:Key="FourColumnFirstLabelWidth">70</GridLength>
        <GridLength x:Key="FourColumnFirstValueWidth">230</GridLength>
        <GridLength x:Key="FourColumnSecondLabelWidth">70</GridLength>
        <GridLength x:Key="FourColumnSecondValueWidth">*</GridLength>
        
        <!-- 阴影效果 -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="12" ShadowDepth="4" Opacity="0.15"/>
        <DropShadowEffect x:Key="ButtonShadow" BlurRadius="8" ShadowDepth="2" Opacity="0.2"/>
        
        <!-- 样式 -->
        <Style x:Key="InfoItemStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>
        
        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource LightTextColor}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        
        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        
        <Style x:Key="CopyButtonStyle" TargetType="Button">
            <Setter Property="Content" Value="📋"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="ToolTip" Value="复制到剪贴板"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Margin" Value="0,15,0,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        
        <Style x:Key="MainButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004B87"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        
        <!-- 左侧：图片上传和预览区域 -->
        <Border Grid.Column="0" Background="#F8F9FA" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- 标题 -->
                <TextBlock Grid.Row="0" Text="图片上传" FontSize="16" FontWeight="Bold" 
                          HorizontalAlignment="Center" Margin="10,15,10,10" 
                          Foreground="{StaticResource TextColor}" 
                          FontFamily="Segoe UI"/>
                
                <!-- 上传按钮区域 -->
                <Border Grid.Row="1" Background="Transparent" Margin="20,5,20,15">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Name="SelectFileButton" Content="📁 选择图片文件" 
                               Style="{StaticResource MainButtonStyle}" 
                               Margin="0,0,15,0"/>
                        <TextBlock Text="或拖拽图片到下方区域" FontSize="12" 
                                  Foreground="{StaticResource LightTextColor}" 
                                  VerticalAlignment="Center" 
                                  FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>
                
                <!-- 图片预览区域 -->
                <Border Grid.Row="2" Name="UploadArea" Background="White" 
                        BorderBrush="{StaticResource BorderColor}" 
                        BorderThickness="1" Margin="20" CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                    </Border.Effect>
                    
                    <Grid>
                        <!-- 上传提示 -->
                        <StackPanel Name="UploadHintPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="📷" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="拖拽图片到此处上传" FontSize="14" HorizontalAlignment="Center" 
                                      Foreground="{StaticResource LightTextColor}" 
                                      Margin="0,0,0,5" 
                                      FontFamily="Segoe UI"/>
                        </StackPanel>
                        
                        <!-- 图片预览 -->
                        <Image Name="PreviewImage" Stretch="Uniform" MaxWidth="300" MaxHeight="300" 
                              HorizontalAlignment="Center" VerticalAlignment="Center" 
                              Visibility="Collapsed" 
                              Margin="20"/>
                    </Grid>
                </Border>
                
                <!-- 状态信息 -->
                <TextBlock Grid.Row="3" Name="StatusText" Text="等待上传图片..." 
                          HorizontalAlignment="Center" Margin="10,15,10,15" 
                          Foreground="{StaticResource LightTextColor}"
                          TextWrapping="Wrap" 
                          TextAlignment="Center" 
                          FontFamily="Segoe UI" 
                          FontSize="12"/>
            </Grid>
        </Border>
        
        <!-- 右侧：信息显示区域 -->
        <Border Grid.Column="1" Background="#F8F9FA">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 标题 -->
                <TextBlock Grid.Row="0" Text="图片信息" FontSize="16" FontWeight="Bold" 
                          HorizontalAlignment="Center" Margin="10,15,10,10" 
                          Foreground="{StaticResource TextColor}" 
                          FontFamily="Segoe UI"/>
                
                <!-- 信息显示区域 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
                    <Grid>
                        <Border Name="InfoPanelBorder" Visibility="Collapsed" 
                                Background="White" 
                                BorderBrush="{StaticResource BorderColor}" 
                                BorderThickness="1" 
                                CornerRadius="12" 
                                Padding="25" 
                                Margin="0,0,0,20"
                                TextOptions.TextRenderingMode="ClearType"
                                TextOptions.TextFormattingMode="Display">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                            </Border.Effect>
                            <StackPanel Name="InfoPanel">
                            
                            <!-- 基本信息 -->
                            <TextBlock Text="基本信息" Style="{StaticResource SectionTitleStyle}"/>
                            
                            <!-- 文件名称 -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{StaticResource TwoColumnLabelWidth}"/>
                                    <ColumnDefinition Width="{StaticResource TwoColumnValueWidth}"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="文件名称：" Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Name="FileNameText" Style="{StaticResource InfoValueStyle}"/>
                                    <Button Name="CopyFileNameButton" Style="{StaticResource CopyButtonStyle}" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- 文件大小和文件格式 -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{StaticResource FourColumnFirstLabelWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnFirstValueWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnSecondLabelWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnSecondValueWidth}"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- 文件大小 -->
                                <TextBlock Grid.Column="0" Text="文件大小：" Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Name="FileSizeText" Style="{StaticResource InfoValueStyle}"/>
                                    <Button Name="CopyFileSizeButton" Style="{StaticResource CopyButtonStyle}" Margin="5,0,0,0"/>
                                </StackPanel>
                                
                                <!-- 文件格式 -->
                                <TextBlock Grid.Column="2" Text="文件格式：" Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Name="FileFormatText" Style="{StaticResource InfoValueStyle}"/>
                                    <Button Name="CopyFileFormatButton" Style="{StaticResource CopyButtonStyle}" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- EXIF信息 -->
                            <TextBlock Text="EXIF信息" Style="{StaticResource SectionTitleStyle}"/>
                            
                            <!-- 创建时间 -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{StaticResource TwoColumnLabelWidth}"/>
                                    <ColumnDefinition Width="{StaticResource TwoColumnValueWidth}"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="创建时间：" Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Name="CreationTimeText" Style="{StaticResource InfoValueStyle}"/>
                                    <Button Name="CopyCreationTimeButton" Style="{StaticResource CopyButtonStyle}" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- 分辨率和相机型号 -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{StaticResource FourColumnFirstLabelWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnFirstValueWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnSecondLabelWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnSecondValueWidth}"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- 分辨率 -->
                                <TextBlock Grid.Column="0" Text="分辨率：" Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Name="ResolutionText" Style="{StaticResource InfoValueStyle}"/>
                                    <Button Name="CopyResolutionButton" Style="{StaticResource CopyButtonStyle}" Margin="5,0,0,0"/>
                                </StackPanel>
                                
                                <!-- 相机型号 -->
                                <TextBlock Grid.Column="2" Text="相机型号：" Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Name="CameraModelText" Style="{StaticResource InfoValueStyle}"/>
                                    <Button Name="CopyCameraModelButton" Style="{StaticResource CopyButtonStyle}" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- 地理位置信息 -->
                            <TextBlock Text="地理位置" Style="{StaticResource SectionTitleStyle}"/>
                            
                            <!-- 纬度和经度 -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{StaticResource FourColumnFirstLabelWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnFirstValueWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnSecondLabelWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnSecondValueWidth}"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- 纬度 -->
                                <TextBlock Grid.Column="0" Text="纬度：" Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Name="LatitudeText" Style="{StaticResource InfoValueStyle}"/>
                                    <Button Name="CopyLatitudeButton" Style="{StaticResource CopyButtonStyle}" Margin="5,0,0,0"/>
                                </StackPanel>
                                
                                <!-- 经度 -->
                                <TextBlock Grid.Column="2" Text="经度：" Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Name="LongitudeText" Style="{StaticResource InfoValueStyle}"/>
                                    <Button Name="CopyLongitudeButton" Style="{StaticResource CopyButtonStyle}" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Grid>
                            
                            <TextBlock Text="坐标格式" Style="{StaticResource SectionTitleStyle}"/>
                            
                            <!-- 纬度,经度和经度,纬度 -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{StaticResource FourColumnFirstLabelWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnFirstValueWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnSecondLabelWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnSecondValueWidth}"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- 纬度,经度 -->
                                <TextBlock Grid.Column="0" Text="纬度,经度：" Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Name="LatLngText" Style="{StaticResource InfoValueStyle}"/>
                                    <Button Name="CopyLatLngButton" Style="{StaticResource CopyButtonStyle}" Margin="5,0,0,0"/>
                                </StackPanel>
                                
                                <!-- 经度,纬度 -->
                                <TextBlock Grid.Column="2" Text="经度,纬度：" Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Name="LngLatText" Style="{StaticResource InfoValueStyle}"/>
                                    <Button Name="CopyLngLatButton" Style="{StaticResource CopyButtonStyle}" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Grid>
                            
                            <TextBlock Text="GCJ-02坐标" Style="{StaticResource SectionTitleStyle}"/>
                            
                            <!-- GCJ-02坐标 -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{StaticResource FourColumnFirstLabelWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnFirstValueWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnSecondLabelWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnSecondValueWidth}"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- GCJ-02纬度 -->
                                <TextBlock Grid.Column="0" Text="GCJ-02纬度：" Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Name="GcjLatitudeText" Style="{StaticResource InfoValueStyle}"/>
                                    <Button Name="CopyGcjLatitudeButton" Style="{StaticResource CopyButtonStyle}" Margin="5,0,0,0"/>
                                </StackPanel>
                                
                                <!-- GCJ-02经度 -->
                                <TextBlock Grid.Column="2" Text="GCJ-02经度：" Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Name="GcjLongitudeText" Style="{StaticResource InfoValueStyle}"/>
                                    <Button Name="CopyGcjLongitudeButton" Style="{StaticResource CopyButtonStyle}" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- GCJ-02坐标格式 -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{StaticResource FourColumnFirstLabelWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnFirstValueWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnSecondLabelWidth}"/>
                                    <ColumnDefinition Width="{StaticResource FourColumnSecondValueWidth}"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- GCJ-02 纬度,经度 -->
                                <TextBlock Grid.Column="0" Text="GCJ-02(纬度,经度)：" Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Name="GcjLatLngText" Style="{StaticResource InfoValueStyle}"/>
                                    <Button Name="CopyGcjLatLngButton" Style="{StaticResource CopyButtonStyle}" Margin="5,0,0,0"/>
                                </StackPanel>
                                
                                <!-- GCJ-02 经度,纬度 -->
                                <TextBlock Grid.Column="2" Text="GCJ-02(经度,纬度)：" Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Name="GcjLngLatText" Style="{StaticResource InfoValueStyle}"/>
                                    <Button Name="CopyGcjLngLatButton" Style="{StaticResource CopyButtonStyle}" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- 地图显示 -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,15,0,8">
                                <TextBlock Text="地图位置" Style="{StaticResource SectionTitleStyle}" Margin="0,0,10,0"/>
                                <Button Name="OpenMapButton" Content="🌍 打开地图" Style="{StaticResource MainButtonStyle}" Padding="10,5" FontSize="12"/>
                            </StackPanel>
                            <Border Name="MapBorder" Background="#F0F0F0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8" Height="300" Margin="0,0,0,0">
                                <WebBrowser Name="MapWebBrowser" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                            </Border>
                            
                            </StackPanel>
                        </Border>
                        
                        <!-- 无图片时的提示 -->
                        <TextBlock Name="NoImageText" Text="请上传图片以查看详细信息" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center" 
                                  FontSize="14" 
                                  Foreground="{StaticResource LightTextColor}" 
                                  TextAlignment="Center" 
                                  FontFamily="Segoe UI"/>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>