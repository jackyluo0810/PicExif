## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Configuration files with secrets
appsettings.json
appsettings.*.json
!appsettings.json.example

# Publish directories
publish/
Release/

# Keep release zip packages
# PicExif-*.zip

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

